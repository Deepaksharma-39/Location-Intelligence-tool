# ==========================================================
# Location Intelligence Platform (In-house) - Environment Template
# Date: 2026-04-18
# Copy to `.env` in root, and optionally split into backend/.env + frontend/.env
# ==========================================================

# -----------------------------
# Core Runtime
# -----------------------------
NODE_ENV=development
LOG_LEVEL=info
APP_NAME=Location Intelligence Platform
APP_REGION=india
APP_TIMEZONE=Asia/Kolkata

# -----------------------------
# Frontend (Vite)
# -----------------------------
VITE_APP_NAME=GeoPulse IQ
VITE_APP_ENV=development
VITE_API_BASE_URL=http://localhost:4000/api
VITE_HEALTHCHECK_URL=http://localhost:4000/health
VITE_MAP_PROVIDER=google
VITE_GOOGLE_MAPS_API_KEY=
VITE_MAPBOX_ACCESS_TOKEN=
VITE_MAP_DEFAULT_LAT=19.0760
VITE_MAP_DEFAULT_LNG=72.8777
VITE_MAP_DEFAULT_ZOOM=11
VITE_SENTRY_DSN=
VITE_POSTHOG_KEY=
VITE_ENABLE_DEBUG_TOOLS=true
VITE_ENABLE_DEMO_DATA=true

# -----------------------------
# Backend API
# -----------------------------
PORT=4000
FRONTEND_URL=http://localhost:5173
API_PREFIX=/api
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=120
REQUEST_TIMEOUT_MS=15000
ENABLE_SWAGGER=true

# -----------------------------
# Authentication & Authorization
# -----------------------------
AUTH_PROVIDER=internal
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
BCRYPT_SALT_ROUNDS=12
SESSION_SECRET=
ALLOWED_ADMIN_EMAILS=

# -----------------------------
# AI Providers (Primary + Backup)
# -----------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_REASONING_MODEL=o4-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
GOOGLE_AI_API_KEY=
GOOGLE_AI_MODEL=gemini-2.5-pro
ENABLE_AI_FALLBACK=true
AI_RESPONSE_TEMPERATURE=0.2
AI_MAX_OUTPUT_TOKENS=1200
AI_SYSTEM_PROMPT_VERSION=v1

# -----------------------------
# Geospatial & Maps Data Sources
# -----------------------------
GOOGLE_MAPS_API_KEY=
MAPBOX_ACCESS_TOKEN=
HERE_API_KEY=
BING_MAPS_API_KEY=
OVERPASS_ENDPOINT=https://overpass-api.de/api/interpreter
OPENSTREETMAP_NOMINATIM_URL=https://nominatim.openstreetmap.org

# -----------------------------
# Mobility / Footfall / Traffic Data
# -----------------------------
TOMTOM_API_KEY=
MAPMYINDIA_CLIENT_ID=
MAPMYINDIA_CLIENT_SECRET=
MOBILITY_DATA_PROVIDER=synthetic
MOBILITY_REFRESH_CRON=0 */6 * * *

# -----------------------------
# Business, POI & Real Estate Data
# -----------------------------
FOURSQUARE_API_KEY=
YELP_API_KEY=
GOOGLE_PLACES_API_KEY=
REAL_ESTATE_PROVIDER_API_KEY=
CENSUS_PROVIDER_API_KEY=
LOCAL_COMMERCIAL_DATA_API_KEY=

# -----------------------------
# Forecasting / ML Services
# -----------------------------
ML_SERVICE_URL=http://localhost:9000
ML_SERVICE_API_KEY=
FORECAST_HORIZON_DAYS=180
MODEL_RETRAIN_CRON=0 3 * * 0
FEATURE_STORE_PROVIDER=redis

# -----------------------------
# Database / Cache / Search
# -----------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/location_intelligence
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20
REDIS_URL=redis://localhost:6379
ELASTICSEARCH_URL=http://localhost:9200
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# -----------------------------
# Storage & Files
# -----------------------------
S3_BUCKET=
S3_REGION=ap-south-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
SIGNED_URL_EXPIRY_SEC=900
REPORT_OUTPUT_DIR=./storage/reports

# -----------------------------
# Messaging / Async Processing
# -----------------------------
RABBITMQ_URL=amqp://guest:guest@localhost:5672
KAFKA_BROKERS=localhost:9092
QUEUE_PREFIX=lip
WORKER_CONCURRENCY=5

# -----------------------------
# Observability / Monitoring
# -----------------------------
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=location-intelligence-api
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9464

# -----------------------------
# Notifications
# -----------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMS_PROVIDER_API_KEY=
WHATSAPP_PROVIDER_API_KEY=

# -----------------------------
# Security / Compliance
# -----------------------------
ENCRYPTION_KEY=
ENABLE_PII_MASKING=true
AUDIT_LOG_RETENTION_DAYS=365
IP_ALLOWLIST=

# -----------------------------
# Feature Flags
# -----------------------------
FEATURE_AI_ADVISOR=true
FEATURE_DOOH_INTELLIGENCE=true
FEATURE_MIGRATION_INSIGHTS=true
FEATURE_REPORT_EXPORT=false
FEATURE_REALTIME_TRACKING=false

# -----------------------------
# Dev / Testing
# -----------------------------
SEED_DEMO_DATA=true
USE_MOCK_EXTERNAL_APIS=true
CYPRESS_BASE_URL=http://localhost:5173
PLAYWRIGHT_BASE_URL=http://localhost:5173
